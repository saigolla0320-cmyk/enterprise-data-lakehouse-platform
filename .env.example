# Copy to .env and fill in. Never commit .env.

# DBT
DBT_TARGET=dev
DBT_DB_PATH=../data/gold/lakehouse.duckdb

# Snowflake (prod target)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=LAKEHOUSE
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_SCHEMA=dbt_marts

# Source systems
CRM_DB_CONNECTION=postgresql://user:pass@host:5432/crm

# Azure (Terraform)
ARM_TENANT_ID=
ARM_SUBSCRIPTION_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
